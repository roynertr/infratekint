---
/**
 * Minimal consent banner: documents language preference + informs before optional analytics.
 */

// components
import Button from "@components/Button/Button.astro";

// utils
import { getLocalizedRoute } from "@js/translationUtils";
import { getLocaleFromUrl } from "@js/localeUtils";

const currLocale = getLocaleFromUrl(Astro.url);

const copy =
  currLocale === "es"
    ? {
        intro:
          "Usamos cookies esenciales para recordar su idioma. Si más adelante incorporamos estadísticas opcionales, podrá rechazarlas aquí.",
        privacy: "Política de privacidad",
        accept: "Entendido",
        decline: "Solo necesarias",
      }
    : {
        intro:
          "We use essential cookies to remember your language choice. Optional analytics cookies will only load if we add them and you consent.",
        privacy: "Privacy Policy",
        accept: "OK",
        decline: "Essential only",
      };
---

<div id="accept-banner" class="fixed inset-x-4 bottom-4 z-50 hidden justify-center md:inset-x-8 md:bottom-8">
  <div
    class="border-brand-botticelli/45 bg-brand-bg text-brand-botticelli flex max-w-2xl flex-wrap items-center justify-center gap-x-6 gap-y-3 rounded-2xl border px-5 py-4 shadow-xl shadow-black/20"
    role="dialog"
    aria-labelledby="cookie-banner-title"
    aria-live="polite"
  >
    <div id="cookie-banner-title" class="text-center text-sm leading-snug md:text-left md:text-base">
      {copy.intro}{" "}
      <a
        href={getLocalizedRoute(currLocale, "/privacy-policy")}
        class="text-brand-malibu underline decoration-brand-malibu/50 underline-offset-2 transition hover:decoration-brand-malibu"
        >{copy.privacy}</a
      >.
    </div>
    <div class="flex shrink-0 flex-wrap justify-center gap-2">
      <Button variant="primary" type="button" data-cc-accept>{copy.accept}</Button>
      <Button variant="outline" type="button" data-cc-decline>{copy.decline}</Button>
    </div>
  </div>
</div>

<script>
  function getCookieConsent() {
    try {
      const consent = document.cookie.match(/cookie-consent=([^;]+)/)?.[1];
      return consent;
    } catch {
      return "unk";
    }
  }

  function cookieConsentSetup() {
    const cookieBanner = document.getElementById("accept-banner");
    const acceptButton = cookieBanner?.querySelector("[data-cc-accept]");
    const declineButton = cookieBanner?.querySelector("[data-cc-decline]");

    if (!cookieBanner || !acceptButton || !declineButton) return;

    const secure = typeof location !== "undefined" && location.protocol === "https:" ? "; secure" : "";
    const persist = "; path=/; max-age=31536000; samesite=lax" + secure;

    const consent = getCookieConsent();
    if (consent !== "accept" && consent !== "decline") {
      cookieBanner.classList.add("flex");
      cookieBanner.classList.remove("hidden");
    }

    const newAccept = acceptButton.cloneNode(true) as HTMLButtonElement;
    const newDecline = declineButton.cloneNode(true) as HTMLButtonElement;
    acceptButton.replaceWith(newAccept);
    declineButton.replaceWith(newDecline);

    newAccept.addEventListener("click", () => {
      cookieBanner.classList.add("hidden");
      cookieBanner.classList.remove("flex");
      document.cookie = `cookie-consent=accept${persist}`;
    });

    newDecline.addEventListener("click", () => {
      cookieBanner.classList.add("hidden");
      cookieBanner.classList.remove("flex");
      document.cookie = `cookie-consent=decline${persist}`;
    });
  }

  cookieConsentSetup();
  document.addEventListener("astro:after-swap", cookieConsentSetup);
</script>
