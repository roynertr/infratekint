# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# Recipient (default: info@infratekint.com)
CONTACT_TO_EMAIL=info@infratekint.com

# Sender — use a verified domain in Resend, e.g. "InfraTek <info@infratekint.com>"
# For testing only, Resend provides onboarding@resend.dev (limited recipients).
CONTACT_FROM_EMAIL=

# --- GitHub Actions (Cloudflare deploy) — not used locally; add in repo Settings → Secrets → Actions:
# CLOUDFLARE_API_TOKEN — API token with "Account" → "Cloudflare Pages" → Edit (and read account if prompted)
# (accountId for GitHub Actions is in .github/workflows/deploy-cloudflare.yml — not in wrangler.toml for Pages)
