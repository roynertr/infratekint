---
/**
 * * These are medium cards with icons, titles, and text. With title first
 * This looks best with 3 or 6 cards
 *
 * ! I copy all icons into the src/icons folder and recommend you do the same
 * ! If the icon is at src/icons/tabler/paint.svg then you put in "tabler/paint"
 */

// components
import FeatureCard from "@components/FeatureCard/FeatureCardMedium.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";

interface FeatureData {
  icon: string;
  title: string;
  text: string;
}

const currLocale = getLocaleFromUrl(Astro.url);

// data
const featureDataByLocale: Record<string, FeatureData[]> = {
  en: [
    {
      icon: "tabler/paint",
      title: "Model quality",
      text: `Coordinated BIM deliverables with clear standards, validation, and documentation teams can trust.`,
    },
    {
      icon: "tabler/heart",
      title: "Practical value",
      text: `We focus on workflows that reduce rework, clarify responsibilities, and support better handover.`,
    },
    {
      icon: "tabler/clock",
      title: "Reliable delivery",
      text: `Remote-ready collaboration and structured information keep decisions moving without adding bureaucracy.`,
    },
  ],
  es: [
    {
      icon: "tabler/paint",
      title: "Calidad del modelo",
      text: `Entregables BIM coordinados, con estándares claros, validación técnica y documentación confiable.`,
    },
    {
      icon: "tabler/heart",
      title: "Valor práctico",
      text: `Priorizamos flujos que reducen retrabajo, aclaran responsabilidades y mejoran la toma de decisiones.`,
    },
    {
      icon: "tabler/clock",
      title: "Entrega confiable",
      text: `La colaboración remota, el CDE y la información estructurada mantienen el proyecto alineado hasta el handover.`,
    },
  ],
};

const featureData = featureDataByLocale[currLocale];

const introCopy =
  currLocale === "es"
    ? {
        title: "Experiencia BIM para equipos de diseño, obra y operación",
        paragraph:
          "Combinamos gestión BIM, control de calidad de modelos, COBie, Open BIM y desarrollo de software para que la información del proyecto sea útil, trazable y sostenible.",
      }
    : null;
---

<section
  id="feature-cards-medium"
  class="overflow-hidden bg-[url('/assets/pattern-light.svg')] bg-center bg-no-repeat py-12 md:py-20 dark:bg-[url('/assets/pattern-dark.svg')]"
>
  <div class="site-container">
    {
      introCopy && (
        <div class="mx-auto mb-12 max-w-4xl text-center md:mb-16" data-mos="fade-up">
          <h2 class="h2 mb-4">{introCopy.title}</h2>
          <p class="description text-lg text-pretty md:text-xl">{introCopy.paragraph}</p>
        </div>
      )
    }
    <div id="trigger-medium-cards" class="grid gap-4 md:grid-cols-3" data-mos="fade-left">
      {
        featureData.map((feature, idx) => (
          <FeatureCard title={feature.title} text={feature.text} icon={feature.icon} />
        ))
      }
    </div>
  </div>
</section>
