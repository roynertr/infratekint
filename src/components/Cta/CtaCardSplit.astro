---
/**
 * * CTA split with text left and button on the right, with primary color background and light text
 */

import { Icon } from "astro-icon/components";

// components
import Button from "@components/Button/Button.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getLocalizedRoute } from "@js/translationUtils";

const currLocale = getLocaleFromUrl(Astro.url);
const copy = {
  en: {
    title: "Ready to make your project data work harder?",
    description: "Let's align BIM, COBie, and digital delivery around your next milestone.",
    button: "Contact INFRATEK",
  },
  es: {
    title: "¿Listo para mejorar la información de su proyecto?",
    description:
      "Alineemos BIM, COBie, captura de realidad y entrega digital con su próximo hito.",
    button: "Contactar a INFRATEK",
  },
} as const;

const t = copy[currLocale];
---

<section class="py-10">
  <div class="site-container">
    <div class="bg-brand-bg relative overflow-hidden rounded-3xl px-16 py-11 shadow-xl shadow-brand-bg/10 md:py-20">
      <Icon
        name="atlas/dots3"
        class="text-accent-4 absolute top-0 left-4 z-10 size-16"
        aria-hidden="true"
      />
      <Icon
        name="atlas/dots3"
        class="text-accent-4 absolute right-4 bottom-0 z-10 size-16"
        aria-hidden="true"
      />
      <Icon
        name="atlas/wave-bg-basic"
        class="absolute top-1/2 left-1/2 h-full w-auto -translate-x-1/2 -translate-y-1/2 object-cover text-black/5"
        aria-hidden="true"
      />

      <div class="relative z-20 -m-3 flex flex-wrap items-center">
        <div class="w-full p-3 md:w-1/2">
          <h2 class="mb-6 text-4xl font-bold tracking-tighter text-white">
            {t.title}
          </h2>
          <p class="text-brand-cruise font-semibold">{t.description}</p>
        </div>
        <div class="flex w-full p-3 md:w-1/2 md:justify-end">
          <Button variant="outline" href={getLocalizedRoute(currLocale, "/contact")} class="shadow-none">
            {t.button}
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
