---
// components
import FooterLink from "@components/Footer/FooterLink.astro";
import SiteLogo from "@components/SiteLogo/SiteLogo.astro";
// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData, getLocalizedRoute } from "@js/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);

const today = new Date();
---

<footer class="text-base-500 mt-auto overflow-x-clip border-t border-brand-botticelli/25 pt-16 pb-12 font-medium">
  <div class="site-container">
    <div class="mt-6 flex flex-wrap items-center justify-between gap-6">
      <SiteLogo />
      <div class="flex flex-wrap gap-x-4">
        <FooterLink href={getLocalizedRoute(currLocale, "/about")}>
          {currLocale === "es" ? "Nosotros" : "About"}
        </FooterLink>
        <FooterLink href={getLocalizedRoute(currLocale, "/portfolio")}>
          {currLocale === "es" ? "Portafolio" : "Portfolio"}
        </FooterLink>
        <FooterLink href={getLocalizedRoute(currLocale, "/blog")}>Blog</FooterLink>
        <FooterLink href={getLocalizedRoute(currLocale, "/contact")}>
          {currLocale === "es" ? "Contacto" : "Contact"}
        </FooterLink>
        <FooterLink href={getLocalizedRoute(currLocale, "/privacy-policy")}>
          {currLocale === "es" ? "Privacidad" : "Privacy"}
        </FooterLink>
        <FooterLink href={getLocalizedRoute(currLocale, "/terms")}>
          {currLocale === "es" ? "Términos" : "Terms"}
        </FooterLink>
      </div>
    </div>
  </div>
  <div class="text-base-400 mt-8 border-t border-brand-botticelli/25 pt-8 text-sm">
    <div class="site-container mt-6 flex flex-wrap justify-between gap-6">
      <div class="my-auto">
        &copy; {today.getFullYear()}
        {" "}{siteData.name}. {currLocale === "es" ? "Todos los derechos reservados." : "All rights reserved."}
      </div>
      <div class="flex flex-col items-end gap-1 text-right">
        <a class="text-brand-malibu hover:text-brand-green transition" href={`mailto:${siteData.contact.email}`}>
          {siteData.contact.email}
        </a>
        <a
          class="text-brand-malibu hover:text-brand-green transition"
          href={`tel:${siteData.contact.phone.replace(/\D/g, "")}`}
        >
          {siteData.contact.phone}
        </a>
      </div>
    </div>
  </div>
</footer>
