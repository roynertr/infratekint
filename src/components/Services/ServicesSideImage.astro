---
/**
 * * These are alternating side cards with titles, text, and images
 * Recommend using 2 or 3 cards in a row
 */
import ServiceCard from "@components/ServiceCard/ServiceCardSideImage.astro";
import Badge from "@components/Badge/Badge.astro";

import { getCollection, type CollectionEntry } from "astro:content";
import { filterCollectionByLanguage, getLocaleFromUrl } from "@js/localeUtils";

const currLocale = getLocaleFromUrl(Astro.url);

const services = await getCollection("services", ({ data }) => data.draft !== true);
const serviceData = filterCollectionByLanguage(services, currLocale).sort(
  (a, b) => a.data.order - b.data.order,
) as CollectionEntry<"services">[];

const copy = {
  en: {
    badge: "Services",
    title: "Solutions across the project lifecycle",
    description: "BIM, structured handover, and tailored software scoped to your standards, tools, and schedule.",
    learnMoreAbout: "Learn more about",
  },
  es: {
    badge: "Servicios",
    title: "Soluciones para todo el ciclo de vida del proyecto",
    description: "BIM, entrega estructurada y software a medida según sus estándares, herramientas y calendario.",
    learnMoreAbout: "Conocer más sobre",
  },
} as const;

const t = copy[currLocale];
---

<section id="services-side-image" class="overflow-hidden py-24 md:py-28">
  <div class="site-container">
    <div class="mx-auto mb-16 text-center md:mb-20 md:max-w-4xl" data-mos="fade-up">
      <Badge>{t.badge}</Badge>
      <h2 class="h2 mb-4">{t.title}</h2>
      <p class="description text-lg md:text-xl">{t.description}</p>
    </div>
    <div class="flex flex-col gap-16 md:mt-16 md:gap-24">
      {
        serviceData.map((service, idx) => (
          <ServiceCard
            title={service.data.title}
            details={service.data.description}
            image={service.data.image}
            imageDark={service.data.imageDark}
            imageAlt={service.data.heroAlt}
            imageSide={idx % 2 === 0 ? "right" : "left"}
            href={`/services/${service.id}/`}
            idx={idx}
            buttonLabel={`${t.learnMoreAbout} ${service.data.title}`}
          />
        ))
      }
    </div>
  </div>
</section>
