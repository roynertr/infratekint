# Resend — https://resend.com/api-keys
# Required on Vercel (Production + Preview) for POST /api/contact to return 200.
RESEND_API_KEY=

# Recipient (default: info@infratekint.com)
CONTACT_TO_EMAIL=info@infratekint.com

# Sender — use a verified domain in Resend, e.g. "INFRATEK <info@infratekint.com>"
# For testing only, Resend provides onboarding@resend.dev (limited recipients).
CONTACT_FROM_EMAIL=

# Cloudflare Turnstile (optional but recommended for contact form anti-spam)
# Create keys at: https://dash.cloudflare.com/ -> Turnstile
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- OpenRouter — optional local tool: `npm run blog:rewrite` (see README)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-5.5
# REWRITE_BASE_DATE=2026-05-01
# SITE=https://infratekint.com
