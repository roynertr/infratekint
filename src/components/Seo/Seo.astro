---
import { getImage } from "astro:assets";
import { type CollectionEntry } from "astro:content";
import { SEO } from "astro-seo";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);

// component import
import HrefLang from "./HrefLang.astro";
import jsonLDGenerator from "@js/jsonLD";

interface BaseProps {
  title: string;
  description: string;
  noindex?: boolean;
}

interface GenProps extends BaseProps {
  type: "general";
  image?: ImageMetadata;
}

interface BlogProps extends BaseProps {
  type: "blog";
  image: ImageMetadata;
  authors: CollectionEntry<"authors">[];
  postFrontmatter: CollectionEntry<"blog">["data"];
}

const { type, title: titleProp, description: descProp, image, noindex = false } = Astro.props as
  | GenProps
  | BlogProps;

// SSR / view transitions: title can be missing; astro-seo requires openGraph.basic.title, type, image
const title =
  typeof titleProp === "string" && titleProp.trim().length > 0 ? titleProp : siteData.title;
const description =
  typeof descProp === "string" && descProp.trim().length > 0 ? descProp : siteData.description;

let optimizedImage;
let jsonLD;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url);

async function buildOgImage(src: ImageMetadata) {
  return getImage({
    src,
    format: "jpeg",
    quality: "high",
    width: 1200,
    height: 630,
    fit: "cover",
  });
}

// if this is a blog page we do things differently
if (type === "blog") {
  const { authors, postFrontmatter } = Astro.props as BlogProps;

  optimizedImage = await buildOgImage(image);

  jsonLD = jsonLDGenerator({
    type: "blog",
    postFrontmatter: postFrontmatter,
    image: optimizedImage,
    authors: authors,
    canonicalUrl: canonicalUrl,
  });
}
// portfolio and other general pages with a hero image
else if (image) {
  optimizedImage = await buildOgImage(image);

  jsonLD = jsonLDGenerator({
    type: "general",
  });
}
// for general pages without a hero image
else {
  jsonLD = jsonLDGenerator({
    type: "general",
  });
}

const baseForUrls = Astro.site ?? Astro.url;

function absoluteOgImage(src: string): string {
  try {
    return new URL(src, baseForUrls).href;
  } catch {
    return new URL(siteData.defaultImage.src, baseForUrls).href;
  }
}

const imageUrl = optimizedImage?.src
  ? absoluteOgImage(optimizedImage.src)
  : absoluteOgImage(siteData.defaultImage.src);

const ogMime = optimizedImage?.src
  ? "image/jpeg"
  : imageUrl.includes(".jpg") || imageUrl.includes(".jpeg")
    ? "image/jpeg"
    : "image/png";

const twitterHandle = siteData.author.twitter?.trim?.() ?? "";
const twitterOpts =
  twitterHandle.length > 0
    ? {
        site: `@${twitterHandle.replace(/^@/, "")}`,
        creator: `@${twitterHandle.replace(/^@/, "")}`,
        card: "summary_large_image" as const,
        title,
        description,
        image: imageUrl,
      }
    : {
        card: "summary_large_image" as const,
        title,
        description,
        image: imageUrl,
      };
---

<SEO
  title={title}
  description={description}
  canonical={canonicalUrl.toString()}
  openGraph={{
    basic: {
      title: title,
      type: "website",
      image: imageUrl,
      url: canonicalUrl.toString(),
    },
    optional: {
      description: description,
      siteName: siteData.title,
    },
    image: {
      type: ogMime,
      width: Number(optimizedImage?.attributes.width) || 1200,
      height: Number(optimizedImage?.attributes.height) || 630,
      alt: title,
    },
  }}
  twitter={twitterOpts}
  noindex={noindex}
  nofollow={noindex}
/>

<!-- hreflang attributes -->
<HrefLang />

<!-- JSON LD -->
<Fragment set:html={jsonLD} />
