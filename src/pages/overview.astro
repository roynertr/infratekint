---
// main layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import Badge from "@components/Badge/Badge.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getLocalizedRoute } from "@js/translationUtils";

const currLocale = getLocaleFromUrl(Astro.url);

// styles
const overview__heading = "dark:text-base-300 mt-6 mb-4 text-xl font-bold md:text-2xl";
const overview__link =
  "text-base-500 hover:text-base-600 dark:text-base-400 dark:hover:text-base-300 my-[.15rem] leading-snug font-medium transition";
---

<BaseLayout
  title="INFRATEK internal overview"
  description="Internal route map — not indexed."
  noindex={true}
>
  <section
    class="site-container bg-[url('/assets/pattern-light.svg')] bg-center bg-no-repeat py-36 dark:bg-[url('/assets/pattern-dark.svg')]"
  >
    <div class="mx-auto max-w-4xl text-center">
      <Badge>Overview</Badge>
      <h1 class="h1 -mt-3">INFRATEK — internal route map</h1>
      <div class="xs:grid-cols-2 mx-auto mt-10 grid gap-4 md:grid-cols-3">
        <div class="flex flex-col">
          <h3 class={overview__heading}>Main pages</h3>
          <a class={overview__link} href={getLocalizedRoute(currLocale, "/")}>Home</a>
          <a class={overview__link} href={getLocalizedRoute(currLocale, "/about")}>About</a>
          <a class={overview__link} href={getLocalizedRoute(currLocale, "/portfolio")}>Portfolio</a>
          <a class={overview__link} href={getLocalizedRoute(currLocale, "/contact")}>Contact</a>
        </div>

        <div class="flex flex-col">
          <h3 class={overview__heading}>Services &amp; blog</h3>
          <a class={overview__link} href={getLocalizedRoute(currLocale, "/services/bim-services")}
            >BIM Services</a
          >
          <a class={overview__link} href={getLocalizedRoute(currLocale, "/blog")}>Blog</a>
        </div>

        <div class="flex flex-col">
          <h3 class={overview__heading}>Content &amp; legal</h3>
          <a class={overview__link} href={getLocalizedRoute(currLocale, "/elements")}>Elements (MDX)</a>
          <a class={overview__link} href={getLocalizedRoute(currLocale, "/privacy-policy")}
            >Privacy Policy</a
          >
          <a class={overview__link} href={getLocalizedRoute(currLocale, "/terms")}>Terms of Use</a>
          <a class={overview__link} href="/not-a-link/">404 test</a>
          <a
            class={overview__link}
            href={getLocalizedRoute(currLocale, "/rss.xml")}
            target="_blank"
            rel="noopener noreferrer">RSS feed</a
          >
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
