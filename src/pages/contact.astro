---
import { Icon } from "astro-icon/components";

// main layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import ContactForm from "@components/Forms/ContactForm.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
---

<BaseLayout
  title="Contact INFRATEK — BIM, COBie & Digital Project Support"
  description="Reach INFRATEK in the United States or Dominican Republic for BIM coordination, COBie, digital twins, reality capture, and custom tooling."
>
  <div class="site-container mx-auto mt-16 overflow-x-clip">
    <div
      class="w-full bg-[url('/assets/pattern-light.svg')] bg-center bg-no-repeat py-20 text-center md:py-32 dark:bg-[url('/assets/pattern-dark.svg')]"
    >
      <h1 class="h1">Contact us</h1>
      <p class="description mx-auto mt-6 max-w-2xl text-pretty">
        Share a brief note about your project or delivery challenge. We will follow up by email and
        suggest a next step—a call, scoped workshop, or written proposal—as appropriate.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-2">
      <!-- contact form -->
      <div class="mb-12 lg:order-2">
        <ContactForm locale="en" />
      </div>

      <!-- Contact info -->
      <div class="mb-auto grid gap-x-6 gap-y-12 lg:grid-cols-2">
        <!-- Email -->
        <div class="flex flex-col items-center gap-3 lg:items-start">
          <div
            class="bg-brand-bg text-brand-malibu inline-flex size-12 items-center justify-center overflow-hidden rounded-full"
          >
            <Icon name="tabler/mail" class="size-6" />
          </div>
          <h3 class="h3">Email</h3>
          <a href={`mailto:${siteData.contact.email}`} class="description hover:text-base-600 transition"
            >{siteData.contact.email}</a
          >
        </div>

        <!-- Phone -->
        <div class="flex flex-col items-center gap-3 lg:items-start">
          <div
            class="bg-brand-bg text-brand-malibu inline-flex size-12 items-center justify-center overflow-hidden rounded-full"
          >
            <Icon name="tabler/phone" class="size-6" />
          </div>
          <h3 class="h3">Phone</h3>
          <a
            href={`tel:${siteData.contact.phone.replace(/\D/g, "")}`}
            class="description hover:text-base-600 transition">{siteData.contact.phone}</a
          >
        </div>

        <!-- Address -->
        <div class="flex flex-col items-center gap-3 lg:items-start">
          <div
            class="bg-brand-bg text-brand-malibu inline-flex size-12 items-center justify-center overflow-hidden rounded-full"
          >
            <Icon name="tabler/map-pin" class="size-6" />
          </div>
          <h3 class="h3">Offices</h3>
          <div class="description flex flex-col items-center lg:items-start">
            <p>{siteData.contact.address1}</p>
            <p>{siteData.contact.address2}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
