---
import { type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import PortfolioFallbackVisual from "@components/Portfolio/PortfolioFallbackVisual.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getLocalizedRoute } from "@js/translationUtils";
import { formatDate, humanize, normalizeImportedExcerpt } from "@js/textUtils";

interface Props {
  project: CollectionEntry<"portfolio">;
  class?: string;
}

const { project, class: className } = Astro.props as Props;
const currLocale = getLocaleFromUrl(Astro.url);
const { title, description, pubDate, heroImage, categories } = project.data;
---

<article
  data-portfolio-card
  data-categories={categories.join(",")}
  class:list={[
    "group border-base-200/70 dark:border-base-700/70 bg-base-50/80 dark:bg-base-900/60 overflow-hidden rounded-2xl border shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl",
    className,
  ]}
>
  <a
    href={getLocalizedRoute(currLocale, `/portfolio/${project.id}/`)}
    class="block overflow-hidden"
  >
    {
      heroImage ? (
        <Image
          src={heroImage}
          alt={`Project image for ${title}`}
          width={900}
          height={560}
          quality="high"
          class="aspect-[16/10] w-full object-cover transition duration-500 group-hover:scale-105"
        />
      ) : (
        <PortfolioFallbackVisual title={title} />
      )
    }
  </a>

  <div class="p-5 md:p-6">
    <div class="mb-3 flex flex-wrap gap-2">
      {
        categories.slice(0, 3).map((category) => (
          <span class="bg-brand-cruise/60 text-brand-bg dark:bg-brand-malibu/10 dark:text-brand-malibu rounded-full px-3 py-1 text-xs font-semibold uppercase">
            {humanize(category)}
          </span>
        ))
      }
    </div>

    <p class="text-base-400 mb-2 text-sm font-medium">{formatDate(pubDate, currLocale)}</p>

    <a href={getLocalizedRoute(currLocale, `/portfolio/${project.id}/`)}>
      <h2 class="dark:text-base-100 text-xl font-bold tracking-tight hover:underline">
        {title}
      </h2>
    </a>

    <p class="text-base-500 mt-3 line-clamp-3 text-sm leading-6 dark:text-base-300">
      {normalizeImportedExcerpt(description)}
    </p>

    <a
      href={getLocalizedRoute(currLocale, `/portfolio/${project.id}/`)}
      class="text-primary-500 hover:text-primary-600 mt-5 inline-flex items-center gap-1 font-semibold transition-colors"
    >
      {currLocale === "es" ? "Ver proyecto" : "View project"}
      <Icon name="tabler/arrow-narrow-right" class="size-4" />
    </a>
  </div>
</article>
