---
import { Image } from "astro:assets";

// data
import { type TestimonialItem } from "@config/types/configDataTypes";

interface Props extends TestimonialItem {
  rest?: any;
}

const { avatar, initials, name, title, testimonial, ...rest } = Astro.props as TestimonialItem;
---

<div
  class="bg-base-50 dark:bg-base-900 flex flex-col justify-between rounded-md p-4 shadow-sm md:p-8"
  {...rest}
>
  <p class="dark:text-base-100 text-lg font-medium">{testimonial}</p>
  <div class="mt-8 flex items-center gap-4">
    {
      avatar ? (
        <Image src={avatar} alt="" height={100} class="size-12 rounded-full object-cover" />
      ) : (
        <div
          class="border-brand-malibu bg-brand-bg text-brand-malibu flex size-12 shrink-0 items-center justify-center rounded-full border-2 text-sm font-bold"
          aria-hidden="true"
          title={name}
        >
          {initials}
        </div>
      )
    }
    <div>
      <p class="dark:text-base-100 font-semibold">{name}</p>
      <p class="text-base-500 dark:text-base-400">{title}</p>
    </div>
  </div>
</div>
