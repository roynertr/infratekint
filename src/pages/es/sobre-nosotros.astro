---
/**
 * * About page with various sections including some text, team profiles, and CTA
 * Edit the team member information inside src/config/teamData.json.ts
 */
import { Icon } from "astro-icon/components";

// main layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import Profile from "@components/Profile/Profile.astro";
import Button from "@components/Button/Button.astro";
import CtaCardSplit from "@components/Cta/CtaCardSplit.astro";
import Badge from "@components/Badge/Badge.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData, getLocalizedRoute } from "@js/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const teamData = getTranslatedData("teamData", currLocale);
---

<BaseLayout
  title="Sobre INFRATEK"
  description="Conoce la experiencia BIM de INFRATEK, el legado de RTR Engineering y nuestra misión de impulsar Open BIM e innovación colaborativa."
>
  <!-- text section -->
  <section
    class="site-container mx-auto mt-16 bg-[url('/assets/pattern-light-big.svg')] bg-center bg-no-repeat py-24 dark:bg-[url('/assets/pattern-dark-big.svg')]"
  >
    <div class="mb-16 text-center">
      <Badge>Sobre INFRATEK</Badge>
      <h1 class="h1 mb-4">Expertos BIM que convierten datos complejos en decisiones más claras.</h1>
      <p class="description mb-8 text-lg md:text-xl">
        INFRATEK ayuda a propietarios, diseñadores y constructores a mejorar la entrega de
        proyectos con BIM, Open BIM, COBie, gemelos digitales y flujos de gestión de información
        basados en experiencia real de construcción.
      </p>
      <div class="flex justify-center">
        <Button variant="primary" href={getLocalizedRoute(currLocale, "/contact")}>
          Contáctenos
        </Button>
      </div>
    </div>

    <!-- Team info -->
    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        teamData.map((member) => (
          <Profile name={member.name} title={member.title} image={member.image} bio={member.bio} />
        ))
      }
    </div>
  </section>

  <CtaCardSplit />
</BaseLayout>
