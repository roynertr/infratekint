---
/**
 * Contact form — POST /api/contact (Resend). Set RESEND_API_KEY and CONTACT_FROM_EMAIL in production.
 */
import Button from "@components/Button/Button.astro";

interface Props {
  locale?: "en" | "es";
}

const { locale = "en" } = Astro.props;

const strings =
  locale === "es"
    ? {
        name: "Nombre",
        phone: "Teléfono (opcional)",
        email: "Correo",
        message: "Mensaje",
        help: "¿En qué podemos ayudarte?",
        send: "Enviar mensaje",
        sending: "Enviando…",
        okTitle: "Mensaje enviado con exito",
        ok: "Gracias por escribirnos. Recibimos tu mensaje y te responderemos en breve.",
        errTitle: "No pudimos enviarlo",
        err: "Hubo un problema al enviar tu mensaje. Intenta de nuevo en unos minutos.",
        netTitle: "Error de conexión",
        net: "Parece que tu conexión se interrumpió. Revisa internet e inténtalo otra vez.",
        loading: "Enviando tu mensaje…",
        captcha: "Completa la verificación de seguridad para continuar.",
      }
    : {
        name: "Name",
        phone: "Phone (optional)",
        email: "Email",
        message: "Message",
        help: "How can we help?",
        send: "Send message",
        sending: "Sending…",
        okTitle: "Message sent",
        ok: "Thanks for reaching out. We received your message and will get back to you soon.",
        errTitle: "We couldn't send it",
        err: "Something went wrong while sending your message. Please try again in a moment.",
        netTitle: "Connection error",
        net: "Your connection may have dropped. Please check it and try again.",
        loading: "Sending your message…",
        captcha: "Please complete the security check before sending.",
      };

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY as string | undefined;

const i18n = JSON.stringify({
  okTitle: strings.okTitle,
  ok: strings.ok,
  errTitle: strings.errTitle,
  err: strings.err,
  netTitle: strings.netTitle,
  net: strings.net,
  loading: strings.loading,
  sending: strings.sending,
  send: strings.send,
  captcha: strings.captcha,
});
---

<section id="contact" class="mx-auto max-w-3xl min-w-fit rounded-lg">
  <form
    id="contact-form"
    class="flex flex-col gap-4"
    data-locale={locale}
    data-i18n={i18n}
    method="post"
    action="/api/contact"
    novalidate
  >
    <div
      id="contact-form-status"
      class="contact-form-status hidden"
      role="status"
      aria-live="polite"
      aria-atomic="true"
    >
      <span id="contact-form-status-icon" class="mt-0.5" aria-hidden="true"></span>
      <div class="min-w-0 flex-1">
        <p id="contact-form-status-title" class="font-semibold leading-snug"></p>
        <p id="contact-form-status-detail" class="mt-1 text-sm leading-relaxed"></p>
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div class="flex flex-col">
        <label for="contact-name" class="form__label sr-only"
          >{strings.name} <span class="text-brand-jaffa">*</span></label
        >
        <input
          type="text"
          class="form__input"
          name="name"
          id="contact-name"
          placeholder={strings.name}
          required
          autocomplete="name"
        />
      </div>
      <div class="flex flex-col">
        <label for="contact-phone" class="form__label sr-only">{strings.phone}</label>
        <input
          type="tel"
          class="form__input"
          name="phone"
          id="contact-phone"
          inputmode="tel"
          placeholder={strings.phone}
          autocomplete="tel"
        />
      </div>
    </div>
    <div>
      <label for="contact-email" class="form__label sr-only mb-1"
        >{strings.email} <span class="text-brand-jaffa">*</span></label
      >
      <input
        type="email"
        class="form__input"
        name="email"
        id="contact-email"
        inputmode="email"
        placeholder={strings.email}
        required
        autocomplete="email"
      />
    </div>
    <div>
      <label for="contact-message" class="form__label sr-only mb-1"
        >{strings.message} <span class="text-brand-jaffa">*</span></label
      >
      <textarea
        name="message"
        class="form__input"
        id="contact-message"
        rows="5"
        placeholder={strings.help}
        required></textarea>
    </div>
    {
      turnstileSiteKey && (
        <div class="contact-form-captcha">
          <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="auto"></div>
        </div>
      )
    }
    <Button variant="primary" type="submit" id="contact-submit">{strings.send}</Button>
  </form>
</section>

<style>
  @import "tailwindcss/theme" theme(reference);
  @import "@/styles/tailwind-theme.css" theme(reference);

  .contact-form-status {
    @apply flex items-start gap-3 rounded-xl border px-4 py-3 text-sm transition-all duration-200;
  }

  .contact-form-status--loading {
    @apply border-brand-botticelli bg-brand-botticelli/30 text-brand-bg;
  }

  .contact-form-status--success {
    @apply border-brand-green/50 bg-brand-cruise/40 text-brand-bg;
  }

  .contact-form-status--error {
    @apply border-brand-jaffa/60 bg-brand-jaffa/10 text-brand-bg;
  }

  .dark .contact-form-status--loading {
    @apply border-brand-malibu/30 bg-brand-malibu/10 text-brand-malibu;
  }

  .dark .contact-form-status--success {
    @apply border-brand-green/40 bg-brand-green/10 text-brand-cruise;
  }

  .dark .contact-form-status--error {
    @apply border-brand-jaffa/50 bg-brand-jaffa/15 text-brand-cruise;
  }

  #contact-submit[disabled] {
    @apply cursor-not-allowed opacity-70;
  }

  .contact-form-captcha {
    @apply flex justify-start;
  }
</style>

<script>
  import { initContactForm } from "@js/contactForm";

  initContactForm();
  document.addEventListener("astro:page-load", initContactForm);
</script>
{
  turnstileSiteKey && (
    <script
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer
    ></script>
  )
}
